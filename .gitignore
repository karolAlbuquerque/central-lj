# === Monorepo: Java + Node + Docker + IDE ===

# OS
Thumbs.db
Desktop.ini
.DS_Store

# IDEs / Editors
.idea/
*.iml
.vscode/
.classpath
.project
.settings/

# Logs
*.log
logs/

# Docker
**/.docker/

# === Backend (Java/Maven/Spring) ===
backend/target/
backend/.spring-boot-devtools.properties
backend/.factorypath
backend/*.classpath

# IntelliJ / Eclipse / NetBeans artifacts
**/out/
**/.metadata/
**/.recommenders/

# === Frontend (Node/React) ===
frontend/node_modules/
frontend/dist/
frontend/.parcel-cache/
frontend/.cache/
frontend/.eslintcache
frontend/npm-debug.log*
frontend/yarn-debug.log*
frontend/yarn-error.log*
frontend/pnpm-debug.log*
frontend/.vite/
*.tsbuildinfo

# Node / tooling (raiz ou pacotes futuros)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Temporários / sistema
*.tmp
*.temp
*.swp
*~

# Env files (do not commit secrets)
.env
.env.*
!.env.example
!frontend/.env.example

# Coverage
coverage/

# === PlantUML exports (gerados localmente; manter .gitkeep) ===
docs/**/exports/*
!docs/**/exports/.gitkeep

